## Frontend environment variables
#
# Use this when your backend is exposed via ngrok (or any public URL).
#
# Example:
# VITE_API_BASE="https://your-tunnel.ngrok-free.dev"
#
VITE_API_BASE=""

# Discord Activity (Embedded App SDK)
# Create an app in Discord Dev Portal and put its Client ID here.
VITE_DISCORD_CLIENT_ID=""

